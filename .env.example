
## claude 프롬포트: (mongodb의 username, password는 로컬에만 저장)
# 이 파일을 복사해서 .env로 만들고 실제 값을 채워넣으세요.
# cp .env.example .env
#
# .env 자체는 .gitignore에 등록되어 있어 GitHub에 올라가지 않습니다.
# 절대로 실제 비밀번호가 담긴 .env 파일을 커밋하지 마세요.

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?appName=<app-name>
MONGODB_DB_NAME=imms_sdl_os
